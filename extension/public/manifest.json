{
  "manifest_version": 3,
  "name": "HAR Capture Suite",
  "version": "0.1.2",
  "description": "Auto-capture network traffic (incl. cross-origin iframes & workers) from allowlisted domains and stream to the desktop app",
  "permissions": ["debugger", "tabs", "storage", "webNavigation", "alarms", "scripting"],
  "web_accessible_resources": [
    {
      "resources": ["content-captcha.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HAR Capture"
  }
}
