{
  "manifest_version": 3,
  "name": "HAR Capture Suite",
  "version": "0.2.0",
  "description": "Auto-capture network traffic (incl. cross-origin iframes, workers, inline JS, eval, fetch/XHR, beacon) from allowlisted domains and stream to the desktop app",
  "permissions": ["debugger", "tabs", "storage", "webNavigation", "alarms", "scripting", "cookies"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-captcha.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-js-capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content-captcha.js", "content-js-capture.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HAR Capture"
  }
}
