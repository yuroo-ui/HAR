    "mockttp": "^3.17.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.7",
